# Secrets for the velop-watcher systemd service.
#
# install-service.sh copies this to /etc/velop-watcher/velop-watcher.env
# (root-owned, chmod 600). Edit that copy — NOT this template — with real values.
# Only secrets live here; all other settings are hard-coded in run-watcher.sh.

# Router admin password (Basic auth to sysinfo.cgi / JNAP).
VELOP_PASSWORD=changeme
