# Copy to .env and fill in. Do NOT commit a real password.
VELOP_URL=https://10.13.1.1/sysinfo.cgi
VELOP_USER=admin
VELOP_PASSWORD=changeme
# Router uses a self-signed cert; keep false unless you've trusted it.
VELOP_VERIFY_TLS=false
# Optional: JNAP device-list endpoint for untruncated device names. Leave unset
# to derive it from VELOP_URL (https://<host>/JNAP/).
# VELOP_JNAP_URL=https://10.13.1.1/JNAP/
# CrateDB over its HTTP endpoint (port 4200).
CRATE_URL=http://localhost:4200
CRATE_USER=crate
CRATE_PASSWORD=changeme
# OUI/vendor lookups. Run `velop-oui-update` to fetch the manuf file to this
# path; MAC addresses are resolved locally and never sent anywhere.
OUI_MANUF_PATH=manuf
OUI_MANUF_URL=https://www.wireshark.org/download/automated/data/manuf
